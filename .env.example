п»ҝDEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# OpenAI-compatible providers (fill API keys when you apply for them)
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai/api/paas/v4
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
HUNYUAN_API_KEY=
HUNYUAN_BASE_URL=https://api.hunyuan.cloud.tencent.com/v1
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
QIANFAN_API_KEY=
QIANFAN_BASE_URL=https://qianfan.baidubce.com/v2
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Model menu in frontend (grouped by provider and availability)
# The first configured/available model is auto-selected.
AVAILABLE_MODELS=deepseek-v4-flash,deepseek-v4-pro,qwen-max,glm-4.5-air,kimi-k2.6,hunyuan-lite,gpt-4o-mini

# Optional explicit provider mapping (exact model name or prefix)
# If empty, backend uses prefix heuristics like deepseek*/qwen*/glm*/kimi*/gpt*.
MODEL_PROVIDER_OVERRIDES_JSON={"hunyuan-lite":"hunyuan","gpt-4o-mini":"openai"}

# Optional model capability overrides (exact model key or prefix* key)
# Example:
# MODEL_CAPABILITIES_JSON={"qwen-max":{"supports_native_web_search":true,"thinking_style":"qwen","supports_thinking_budget":true,"deep_thinking_budget":3072}}
MODEL_CAPABILITIES_JSON=

# Deep-thinking defaults by provider style mapping
DEEPSEEK_DEEP_REASONING_EFFORT=high
QWEN_DEEP_THINKING_BUDGET=2048

# Optional custom providers (advanced):
# EXTRA_PROVIDER_CONFIGS_JSON={"my_gateway":{"base_url":"https://your-gateway/v1","api_key_env":"MY_GATEWAY_API_KEY"}}
EXTRA_PROVIDER_CONFIGS_JSON=

# Local embedding model for retrieval
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DEVICE=cpu

# Optional web search provider (none | serper | tavily)
# For "directly runnable web search", set provider + API key.
WEB_SEARCH_PROVIDER=tavily
WEB_SEARCH_API_KEY=YOUR_TAVILY_API_KEY
WEB_SEARCH_TOP_K=5

# Cost estimate (unit: per 1M tokens)
# Keep this in sync with your provider's latest official pricing page.
COST_CURRENCY=USD
MODEL_PRICING_JSON={"deepseek-v4-flash":{"input_per_1m_tokens":0.14,"output_per_1m_tokens":0.28},"deepseek-v4-pro":{"input_per_1m_tokens":0.435,"output_per_1m_tokens":0.87}}

# RAG tuning
TOP_K=4
CHUNK_SIZE=800
CHUNK_OVERLAP=120
TEMPERATURE=0.2
MAX_TOKENS=1024
MAX_UPLOAD_MB=20

# Frontend dev server
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional: doc/docx -> pdf preview with LibreOffice
# SOFFICE_BIN=C:\Program Files\LibreOffice\program\soffice.exe

# Optional: ONLYOFFICE professional online editor for doc/docx/xls/xlsx
# Browser uses ONLYOFFICE_DOCUMENT_SERVER_URL to load DocsAPI script.
# Document Server uses PUBLIC_BACKEND_URL to pull original file and callback save.
# еЁҙеҝҡоқҚйҚЈг„ЁоҶ–й—Ӯ?ONLYOFFICE йҗЁеӢ«ж№ҙйҚ§вӮ¬й”ӣе қеў з»”оҲҡе§һжқһ?DocsAPI йҗўоҹ’зҙҡ
ONLYOFFICE_DOCUMENT_SERVER_URL=

# Optional backend-only probe/command URL (when backend cannot access public URL directly).
# йҚҡеәЈоҒ¬йҺәгҲЎжӨҝ/йҚӣжҲ’жҠӨйҺәгғҘеҪӣжөЈи·Ёж•ӨйҗЁеӢ«е”ҙзјғжҲқж№ҙйҚ§вӮ¬й”ӣе қеҪІй–«еӨӣзҙқжөЈ?Docker йҚҰзғҳж«ҷеҜ°е ҹж№Ғйҗўоҹ’зҙҡ
ONLYOFFICE_DOCUMENT_SERVER_INTERNAL_URL=

# ONLYOFFICE зҖ№з‘°ж«’йҚҘзӮ¶зҡҹйҚңеұҫеӘәйҸӮеӣҰж¬ўйҸғжғ°оҶ–й—ӮоҶ»з¶ҳйҚҡеәЈоҒ¬йҗЁеӢ«ж№ҙйҚ§вӮ¬
PUBLIC_BACKEND_URL=http://127.0.0.1:8000

# Optional backend-only URL used by callback downloader when PUBLIC_BACKEND_URL
# is not directly reachable from backend runtime.
PUBLIC_BACKEND_INTERNAL_URL=

# йҸ„оҲҡжғҒйҚҡоҲңж•Ө JWTй”ӣеІҖж•“жөңСғзј“з’Ғ?true
ONLYOFFICE_JWT_ENABLED=true

# жөЈзҠәеҡңе®ёиҫ©ж•“йҺҙж„¶зҙқйҚҡеәЈоҒ¬йҚң?ONLYOFFICE и№Үе‘ҙгҖҸж¶“вӮ¬й‘·?ONLYOFFICE_JWT_SECRET=

# йҸ„оҲҡжғҒж¶“гғҰзүёйҸҚпҝ зҚҷйҚҘзӮ¶зҡҹ token
ONLYOFFICE_VERIFY_CALLBACK_TOKEN=false

# ж·ҮжҝҶз“ЁйҚҡеәўж§ёйҚҡп№ҒР•йҚҷжҲ еӮЁеҜ®жӣҹжҙҝйҸӮ?ONLYOFFICE_AUTO_REBUILD_INDEX_ON_SAVE=true

# incremental: only re-index saved file (recommended)
# full: rebuild entire index after each save
ONLYOFFICE_INDEX_UPDATE_MODE=incremental

# йҚҘзӮ¶зҡҹ token жқ©еӣЁж№Ўз»үжҺ“жҡҹ
ONLYOFFICE_CALLBACK_TTL_SEC=86400
